rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read, write: if true;

      function isSignedIn() {
        return request.auth != null && request.auth.token.email is string;
      }

      function normalizedAuthEmail() {
        return request.auth.token.email.lower();
      }

      function gameDoc() {
        return get(/databases/$(database)/documents/games/$(gameId));
      }

      function joinedPlayerEmails() {
        return gameDoc().data.playerEmails;
      }

      function isJoinedPlayer() {
        return (
          isSignedIn() &&
          gameDoc().exists() &&
          joinedPlayerEmails() is list &&
          joinedPlayerEmails().hasAny([normalizedAuthEmail()])
        );
      }

      match /messages/{messageId} {
        allow read: if isJoinedPlayer();

        allow create: if
          isJoinedPlayer() &&
          request.resource.data.keys().hasOnly([
            'senderId',
            'senderName',
            'senderInitials',
            'text',
            'timestamp',
          ]) &&
          request.resource.data.senderId is string &&
          request.resource.data.senderId == normalizedAuthEmail() &&
          request.resource.data.senderName is string &&
          request.resource.data.senderName.size() > 0 &&
          request.resource.data.senderName.size() <= 80 &&
          request.resource.data.senderInitials is string &&
          request.resource.data.senderInitials.size() > 0 &&
          request.resource.data.senderInitials.size() <= 3 &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 800 &&
          request.resource.data.timestamp == request.time;

        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if !document.matches('games/[^/]+/messages/[^/]+');
    }
  }
}
