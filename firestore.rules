rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      // Public read so the game list works even before sign-in completes.
      allow read: if true;
      // Writes require Firebase Auth (anonymous or Google). Enable Anonymous
      // sign-in in Firebase Console → Authentication → Sign-in method.
      allow create, update, delete: if request.auth != null;
    }
  }
}
